---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { SITE, u } from '../../data/catalog.js';

const cities = await getCollection('cities');
const depotCity = (token) => cities.find((c) => c.data.cityToken === token)?.data ?? null;

const WP = 'https://hartfordrents.com/wp-content/uploads';
// Live /contact-htr/ office order: Chicago, Las Vegas, Orlando.
const offices = [
  {
    name: 'Chicago',
    addr: '3 W College Drive, Arlington Hts., IL 60004',
    phone: '224-801-6018',
    phoneHref: 'tel:+12248016018',
    img: `${WP}/2022/10/pageImage-location-Chicago.jpg`,
    city: depotCity('chicago-il'),
  },
  {
    name: 'Las Vegas',
    addr: '4065 West Mesa Vista Ave, Suite C, Las Vegas, NV 89118',
    phone: '702-286-0010',
    phoneHref: 'tel:+17022860010',
    img: `${WP}/2025/12/pageImage-location-LasVegas.jpg`,
    city: depotCity('las-vegas-nv'),
  },
  {
    name: 'Orlando',
    addr: '9535 Satellite Boulevard, Suite 300, Orlando, FL 32837',
    phone: '407-907-7858',
    phoneHref: 'tel:+14079077858',
    img: `${WP}/2024/10/pageImage-location-Orlando.jpg`,
    city: depotCity('orlando-fl'),
  },
];

// Live /contact-htr/ body copy, verbatim.
const intro = [
  'Hartford provides short-term technology rental solutions to a remarkably diverse customer base across the country.',
  'In most instances our rental services are provided by our own personnel which insures you’ll be getting the focused service, quality equipment and attention to detail we’re known for.',
  'Controlling your set-up, monitoring your event and then executing the take-down are critical, we believe, to maintaining a long term partnership.',
  'In both of our locations we carry an extensive rental inventory of first-rate equipment side-by-side with fully outfitted labs staffed with first-rate technicians.',
  'We ship our products and people wherever they’re needed and make certain that in whatever project we find ourselves, we exceed our customers’ expectations. That’s just who we are.',
];

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact HTR',
  url: `${SITE.url}/contact-htr/`,
  mainEntity: {
    '@type': 'Organization',
    '@id': `${SITE.url}/#organization`,
    contactPoint: [
      {
        '@type': 'ContactPoint',
        telephone: `+1-${SITE.phone}`,
        contactType: 'customer service',
        email: SITE.email,
        areaServed: 'US',
        availableLanguage: 'English',
        hoursAvailable: { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'], opens: '00:00', closes: '23:59' },
      },
      ...offices.map((o) => ({
        '@type': 'ContactPoint',
        telephone: `+1-${o.phone}`,
        contactType: 'customer service',
        areaServed: 'US',
        name: `${SITE.name} — ${o.name}`,
      })),
    ],
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: `${SITE.url}/contact-htr/` },
  ],
};
---

<Base
  title="Contact HTR | Hartford Technology Rentals — 888-520-5667, 24/7"
  description="Contact Hartford Technology Rentals: 888-520-5667, answered 24/7. Offices in Chicago, Las Vegas and Orlando — short-term AV and computing rental solutions, delivered nationwide with our own personnel."
  schema={[breadcrumbSchema, contactSchema]}
>
  <!-- ============ HERO — the directory card (the site's only light hero) ============ -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-[1440px] px-5 pb-10 pt-12 lg:px-10 lg:pb-14 lg:pt-20">
      <div class="hero-line flex flex-wrap items-baseline justify-between gap-x-8 gap-y-3">
        <p class="mono-label flex items-center gap-2 text-ink-3">
          <span class="tally" aria-hidden="true"></span>Lines open · 24/7 technical support · Same-day response
        </p>
        <h1 class="display text-lg text-ink">Contact HTR</h1>
      </div>

      <a href={SITE.phoneHref} class="dial hero-line group mt-10 block w-fit lg:mt-14" style="--hl-delay: 80ms" aria-label={`Call ${SITE.phone} — a person answers, not a menu`}>
        <span class="flex flex-wrap items-baseline text-ink transition-colors duration-300 group-hover:text-signal" aria-hidden="true">
          {SITE.phone.split('').map((ch, i) =>
            ch === '-' ? (
              <span class="dial-ch text-ink-3 transition-colors duration-300 group-hover:text-signal">–</span>
            ) : (
              <span class="dial-ch od" style={`--od-delay: ${160 + i * 60}ms`}>
                <span class="od-col">
                  <span>{(Number(ch) + 3) % 10}</span>
                  <span>{ch}</span>
                </span>
              </span>
            )
          )}
        </span>
        <span class="mono-label mt-4 block text-ink-3 transition-colors group-hover:text-signal">
          Tap to call — a person answers, not a menu
        </span>
      </a>

      <ul class="hero-line mt-12 border-t border-line lg:mt-16" style="--hl-delay: 320ms" role="list">
        {offices.map((o) => (
          <li class="border-b border-line">
            <a href={o.phoneHref} class="dir-row grid grid-cols-[6.5rem_1fr_auto] items-baseline gap-x-6 py-4 sm:grid-cols-[9rem_11rem_1fr_auto] lg:gap-x-10">
              <span class="mono-label text-ink">{o.name}</span>
              <span class="dir-main font-mono text-sm text-ink-2">{o.phone}</span>
              <span class="hidden font-mono text-xs text-ink-3 sm:block">{o.addr}</span>
              <span class="dir-arrow mono-label text-signal">Call →</span>
            </a>
          </li>
        ))}
        <li class="border-b border-line">
          <a href={`mailto:${SITE.email}`} class="dir-row grid grid-cols-[6.5rem_1fr_auto] items-baseline gap-x-6 py-4 sm:grid-cols-[9rem_1fr_auto] lg:gap-x-10">
            <span class="mono-label text-ink">Email</span>
            <span class="dir-main break-all font-mono text-sm text-ink-2">{SITE.email}</span>
            <span class="dir-arrow mono-label text-signal">Write →</span>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <!-- ============ MESSAGE + FORM ============ -->
  <section class="border-b border-line bg-surface/60">
    <div class="mx-auto grid max-w-[1440px] gap-12 px-5 py-14 lg:grid-cols-[1fr_30rem] lg:gap-20 lg:px-10 lg:py-20">
      <div class="reveal">
        <h2 class="display max-w-[18ch] text-[clamp(1.65rem,3.2vw,2.5rem)]">Our own people, wherever you need us</h2>
        <div class="mt-7 max-w-[62ch] space-y-4 text-[0.9375rem] leading-relaxed text-ink-2">
          <p class="text-[1.0625rem] leading-relaxed text-ink">{intro[0]}</p>
          {intro.slice(1).map((p) => <p>{p}</p>)}
        </div>
        <p class="mono-label mt-8 flex items-center gap-2 text-ink-3">
          <span class="tally" aria-hidden="true"></span>We only rent to businesses
        </p>
      </div>

      <div class="reveal">
        <form class="border border-line bg-bg p-6 lg:p-8" data-contact-form novalidate aria-label="Contact HTR">
          <p class="display-sub text-base">Send us a message</p>
          <p class="mt-1.5 text-sm text-ink-3">Every message is answered the same business day.</p>
          <div class="mt-6 grid grid-cols-2 gap-4">
            <label class="col-span-2 block sm:col-span-1">
              <span class="mono-label text-ink-3">Name *</span>
              <input required type="text" name="name" autocomplete="name" class="mt-1.5 w-full border border-line bg-bg px-3 py-2.5 text-sm focus:border-ink" />
            </label>
            <label class="col-span-2 block sm:col-span-1">
              <span class="mono-label text-ink-3">Company *</span>
              <input required type="text" name="company" autocomplete="organization" class="mt-1.5 w-full border border-line bg-bg px-3 py-2.5 text-sm focus:border-ink" />
            </label>
            <label class="col-span-2 block sm:col-span-1">
              <span class="mono-label text-ink-3">Phone</span>
              <input type="tel" name="phone" autocomplete="tel" class="mt-1.5 w-full border border-line bg-bg px-3 py-2.5 text-sm focus:border-ink" />
            </label>
            <label class="col-span-2 block sm:col-span-1">
              <span class="mono-label text-ink-3">Email *</span>
              <input required type="email" name="email" autocomplete="email" class="mt-1.5 w-full border border-line bg-bg px-3 py-2.5 text-sm focus:border-ink" />
            </label>
            <label class="col-span-2 block">
              <span class="mono-label text-ink-3">Comment or message *</span>
              <textarea required name="message" rows="5" class="mt-1.5 w-full resize-y border border-line bg-bg px-3 py-2.5 text-sm focus:border-ink"></textarea>
            </label>
          </div>
          <button type="submit" class="mt-5 w-full bg-ink py-3.5 text-sm font-semibold text-bg transition-colors hover:bg-signal-strong">
            Send message
          </button>
          <p class="mt-3 text-center text-xs text-ink-3">Urgent? Call {SITE.phone} — answered 24/7.</p>
        </form>

        <div class="hidden border border-line bg-bg px-6 py-14 text-center" data-contact-success>
          <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-ink">
            <svg class="h-5 w-5 text-bg" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10.5l4 4 8-9" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"/></svg>
          </span>
          <p class="display-sub mt-5 text-base">Message received</p>
          <p class="mx-auto mt-2 max-w-[32ch] text-sm leading-relaxed text-ink-3">
            A rental specialist will reply the same business day. For anything urgent, call {SITE.phone}.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ OUR LOCATIONS ============ -->
  <section id="locations" class="border-b border-line">
    <div class="mx-auto max-w-[1440px] px-5 py-14 lg:px-10 lg:py-20">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <h2 class="display reveal text-[clamp(1.65rem,3.2vw,2.5rem)]">Our locations</h2>
        <p class="mono-label reveal text-ink-3">Nationwide overnight, both ways</p>
      </div>
      <ul class="mt-8 grid gap-4 md:grid-cols-3" role="list">
        {offices.map((o) => (
          <li class="depot-card reveal group relative overflow-hidden border border-line bg-ink text-bg">
            <img src={o.img} alt={`Hartford Technology Rentals office — ${o.name}`} class="depot-img absolute inset-0 h-full w-full object-cover opacity-50" loading="lazy" width="600" height="400" />
            <div class="relative flex min-h-[260px] flex-col justify-end bg-gradient-to-t from-ink via-ink/60 to-transparent p-6">
              <h3 class="display-sub text-lg">{o.name}</h3>
              <p class="mt-1.5 font-mono text-xs leading-relaxed text-muted-dark">{o.addr}</p>
              <a href={o.phoneHref} class="link-draw mt-3 inline-block w-fit font-mono text-sm text-bg">{o.phone}</a>
              {o.city && (
                <a href={u(o.city.url)} class="mono-label link-draw mt-4 inline-block w-fit text-muted-dark transition-colors hover:text-bg">
                  Rentals in {o.name} →
                </a>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="bg-ink text-bg">
    <div class="mx-auto flex max-w-[1440px] flex-col items-start justify-between gap-8 px-5 py-16 lg:flex-row lg:items-center lg:px-10">
      <div>
        <p class="mono-label mb-3 flex items-center gap-2 text-muted-dark"><span class="tally" aria-hidden="true"></span>Know what gear you need?</p>
        <h2 class="display text-[clamp(1.75rem,4vw,3rem)]">Skip the form — build a quote list</h2>
      </div>
      <button type="button" class="bg-bg px-7 py-4 text-sm font-semibold text-ink transition-colors hover:bg-signal hover:text-white" data-drawer-open>
        Start a quote list
      </button>
    </div>
  </section>
</Base>

<style>
  .hero-line {
    animation: hero-rise 0.7s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) both;
    animation-delay: var(--hl-delay, 0ms);
  }
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: none; }
  }

  /* the dial: giant mono digits, each rolls in like an odometer wheel */
  .dial-ch {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: clamp(2.4rem, 8.5vw, 6rem);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .od {
    display: inline-block;
    overflow: hidden;
    height: 1em;
  }
  .od-col {
    display: block;
    animation: od-roll 0.65s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) both;
    animation-delay: var(--od-delay, 0ms);
  }
  .od-col > span {
    display: block;
    height: 1em;
  }
  @keyframes od-roll {
    from { transform: translateY(0); }
    to { transform: translateY(-1em); }
  }

  /* directory rows: arrow slides in, row text sharpens */
  .dir-arrow {
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.25s ease, transform 0.25s var(--ease-out-quart);
  }
  .dir-row:hover .dir-arrow,
  .dir-row:focus-visible .dir-arrow {
    opacity: 1;
    transform: translateX(0);
  }
  .dir-main { transition: color 0.2s ease; }
  .dir-row:hover .dir-main,
  .dir-row:focus-visible .dir-main { color: var(--color-ink); }

  .depot-img { transition: opacity 0.35s ease, transform 0.7s var(--ease-out-expo); }
  .depot-card:hover .depot-img, .depot-card:focus-within .depot-img {
    opacity: 0.72;
    transform: scale(1.04);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-line { animation: none; }
    .od-col { animation: none; transform: translateY(-1em); }
    .dir-arrow, .dir-main, .depot-img { transition: none; }
  }
</style>

<script>
  // Prototype form: no backend yet — swap to the confirmation state.
  const form = document.querySelector('[data-contact-form]') as HTMLFormElement | null;
  const success = document.querySelector('[data-contact-success]') as HTMLElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;
    form.classList.add('hidden');
    success?.classList.remove('hidden');
    success?.scrollIntoView({ block: 'center', behavior: 'smooth' });
  });
</script>
