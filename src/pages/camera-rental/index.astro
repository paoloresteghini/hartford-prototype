---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import { SITE, CAMERA_PRODUCTS, CAMERA_SUBCATS, u } from '../../data/catalog.js';

const faqs = [
  {
    q: 'Can I rent a camera for a single day?',
    a: 'Yes. We quote daily, weekly and monthly rates, and daily rentals are common for shoots, hearings and hybrid meetings. Overnight shipping both ways means a one-day rental is practical almost anywhere in the country.',
  },
  {
    q: 'Do you rent to individuals?',
    a: 'No — Hartford rents exclusively to businesses, government agencies and school districts. This keeps our fleet enterprise-grade and our insurance and logistics simple for corporate clients.',
  },
  {
    q: 'Is the camera prepped before it ships?',
    a: 'Every unit passes a stringent quality-control process by manufacturer-trained technicians. Camera chains ship configured — lens, viewfinder, controls and cabling tested as a system, not a box of parts.',
  },
  {
    q: 'What if something fails during my event?',
    a: 'Call our 24/7 technical support line and we will troubleshoot immediately. For multi-camera productions we can staff on-site technicians and ship same-day replacements from the nearest depot.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Audio Visual Rentals', item: `${SITE.url}/rent-audio-visual-gear/` },
    { '@type': 'ListItem', position: 3, name: 'Camera Rentals', item: `${SITE.url}/camera-rental/` },
  ],
};

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${SITE.url}/camera-rental/#collection`,
  name: 'Camera Rentals',
  url: `${SITE.url}/camera-rental/`,
  description:
    'Broadcast, PTZ, 4K studio and specialty camera rentals for business events, delivered nationwide with local pickup in Las Vegas, Chicago and Orlando.',
  isPartOf: { '@id': `${SITE.url}/#website` },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: CAMERA_PRODUCTS.length,
    itemListElement: CAMERA_PRODUCTS.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Product',
        name: `${p.brand} ${p.name}`,
        image: `${SITE.url}${p.img}`,
        brand: { '@type': 'Brand', name: p.brand },
        sku: p.sku,
        url: p.href !== '#' ? `${SITE.url}${p.href}` : `${SITE.url}/camera-rental/`,
      },
    })),
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base
  title="Camera Rentals for Business Events | Broadcast, PTZ & 4K | Hartford Technology Rentals"
  description="Rent broadcast cameras, 4K studio chains, PTZ systems, camcorders and lenses for corporate events. Prepped by manufacturer-trained techs, shipped nationwide overnight from Las Vegas, Chicago and Orlando."
  schema={[breadcrumbSchema, collectionSchema, faqSchema]}
  ogImage="/img/camera-hero.jpg"
>
  <!-- ============ PAGE HEADER ============ -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-[1440px] px-5 pt-8 lg:px-10">
      <nav aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-2 font-mono text-xs text-ink-3">
          <li><a href={u('/')} class="link-draw hover:text-ink">Home</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="#" class="link-draw hover:text-ink">Audio Visual</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-ink">Camera Rentals</li>
        </ol>
      </nav>

      <div class="grid gap-10 pb-12 pt-10 lg:grid-cols-[1.5fr_1fr] lg:gap-16 lg:pb-16">
        <div>
          <h1 class="display text-[clamp(2.5rem,6vw,4.5rem)]">Camera rentals</h1>
          <p class="mt-6 max-w-[58ch] text-base leading-relaxed text-ink-2 lg:text-lg">
            Broadcast studio chains, PTZ fleets, camcorders and specialty capture —
            prepped by Panasonic-trained technicians and shipped as tested systems, not boxes of parts.
          </p>
          <p class="mt-4 max-w-[58ch] text-[0.9375rem] leading-relaxed text-ink-3">
            Need to rent a video camera near you? Pick up locally at our Las Vegas, Chicago
            and Orlando depots — or ship overnight to Los Angeles, New York City, Washington
            DC and everywhere between, nationwide both ways. Every camera rental includes
            24/7 technical support.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-5">
            <button type="button" class="bg-ink px-6 py-3.5 text-sm font-semibold text-bg transition-colors hover:bg-signal-strong" data-drawer-open>
              Request a camera quote
            </button>
            <a href={SITE.phoneHref} class="mono-label link-draw text-ink-2">{SITE.phone} · 24/7</a>
          </div>
        </div>
        <div class="reveal-img relative hidden min-h-[300px] overflow-hidden lg:block">
          <img
            src={u('/img/camera-hero.jpg')}
            alt="Camera body and prime lenses arranged on a dark bench"
            class="absolute inset-0 h-full w-full object-cover"
          />
          <p class="mono-label absolute bottom-4 left-4 bg-ink px-2.5 py-1.5 text-bg">Fleet · QC’d before every rental</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FILTER + GRID ============ -->
  <section class="mx-auto max-w-[1440px] px-5 py-12 lg:px-10 lg:py-16">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div class="flex flex-wrap gap-2" role="group" aria-label="Filter by camera type">
        <button type="button" class="filter-chip border border-line px-4 py-2 text-sm font-medium transition-colors hover:border-ink" aria-pressed="true" data-filter-chip="all">
          All cameras
        </button>
        {CAMERA_SUBCATS.map((sub) => (
          <button type="button" class="filter-chip border border-line px-4 py-2 text-sm font-medium transition-colors hover:border-ink" aria-pressed="false" data-filter-chip={sub.filter}>
            {sub.name}
          </button>
        ))}
      </div>
      <p class="mono-label text-ink-3" data-filter-count aria-live="polite">{CAMERA_PRODUCTS.length} units</p>
    </div>

    <div class="mt-8 grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-4" data-filter-grid>
      {CAMERA_PRODUCTS.map((p, i) => (
        <div class="grid-item" data-type={p.type}>
          <ProductCard product={p} eager={i < 4} />
        </div>
      ))}
    </div>

    <p class="mt-8 text-sm text-ink-3">
      Don’t see the model you need? The full fleet is deeper than the site —
      <button type="button" class="link-draw font-medium text-ink" data-drawer-open>ask for it in your quote</button>
      or call {SITE.phone}.
    </p>
  </section>

  <!-- ============ WHY HARTFORD ============ -->
  <section class="border-y border-line bg-paper-dark text-bg">
    <div class="mx-auto max-w-[1440px] px-5 py-16 lg:px-10 lg:py-24">
      <h2 class="reveal display max-w-2xl text-[clamp(1.75rem,4vw,3rem)]">Why production teams rent cameras here</h2>
      <div class="mt-12 grid gap-px overflow-hidden border border-line-dark/60 bg-line-dark/60 md:grid-cols-3">
        <div class="reveal bg-paper-dark p-8 lg:p-10">
          <p class="display-sub text-lg">Systems, not boxes</p>
          <p class="mt-3 text-[0.9375rem] leading-relaxed text-muted-dark">
            Camera chains ship cabled, configured and tested end-to-end — lens, viewfinder,
            CCU and controls arrive as one working system.
          </p>
        </div>
        <div class="reveal bg-paper-dark p-8 lg:p-10">
          <p class="display-sub text-lg">Manufacturer-trained QC</p>
          <p class="mt-3 text-[0.9375rem] leading-relaxed text-muted-dark">
            Panasonic Pro trained staff run every unit through a stringent quality-control
            process between rentals. 96% of our clients rent again.
          </p>
        </div>
        <div class="reveal bg-paper-dark p-8 lg:p-10">
          <p class="display-sub text-lg">24/7 humans</p>
          <p class="mt-3 text-[0.9375rem] leading-relaxed text-muted-dark">
            A technician answers around the clock. On-site crew and same-day replacements
            available from the nearest depot for critical productions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SEO CONTENT (long-form, keyword-carrying) ============ -->
  <section class="border-t border-line bg-surface/60">
    <div class="mx-auto max-w-[1440px] px-5 py-16 lg:px-10 lg:py-20">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-20">
        <div class="reveal">
          <h2 class="display-sub text-lg">Video camera rentals near you</h2>
          <p class="mt-4 max-w-[62ch] text-[0.9375rem] leading-relaxed text-ink-2">
            Need to rent a video camera for an upcoming project? Pick up locally at our
            <a href="#" class="link-draw font-medium text-ink">Las Vegas</a>,
            <a href="#" class="link-draw font-medium text-ink">Chicago</a> and
            <a href="#" class="link-draw font-medium text-ink">Orlando</a> depots, or let us ship
            overnight to Los Angeles, New York City, Washington DC and everywhere between —
            nationwide, both ways. Asking “where can I rent a video camera near me?” The answer
            is right here at HTR, with same-day quotes and unbeatable rental rates on
            professional broadcast gear.
          </p>
        </div>
        <div class="reveal">
          <h2 class="display-sub text-lg">Camera rental reservations for any event</h2>
          <p class="mt-4 max-w-[62ch] text-[0.9375rem] leading-relaxed text-ink-2">
            Rent video, broadcast and 4K cameras from industry-leading brands by the day, week
            or month — or arrange a long-term rental for touring productions and semester
            programs. Every camera rental is maintained by trained technicians between jobs,
            so no technical hiccup derails your shoot, general session, hybrid meeting or
            live stream.
          </p>
        </div>
      </div>
      <div class="mt-12 grid gap-12 border-t border-line pt-12 lg:grid-cols-2 lg:gap-20">
        <div class="reveal">
          <h2 class="display-sub text-lg">A wide-angle view of the fleet</h2>
          <p class="mt-4 max-w-[62ch] text-[0.9375rem] leading-relaxed text-ink-2">
            Our camera rental inventory ranges from minimal-footprint webcams to the full
            studio broadcast experience — PTZ cameras, camcorders and every accessory in
            between, including the trusty shooting riser. We're by your side 24/7 via phone
            and email; reach out with any questions.
          </p>
        </div>
        <div class="reveal">
          <h2 class="display-sub text-lg">Customize your camera order with confidence</h2>
          <p class="mt-4 max-w-[62ch] text-[0.9375rem] leading-relaxed text-ink-2">
            A video camera rental often needs supporting gear. We're your one-stop shop:
            highly sought-after brands for lens rentals, advice on the right package for the
            shots you're after, and shipping for camera rentals to New York, Los Angeles or
            wherever production takes you.
          </p>
        </div>
        <div class="reveal">
          <h2 class="display-sub text-lg">Order fulfillment and quality service</h2>
          <p class="mt-4 max-w-[62ch] text-[0.9375rem] leading-relaxed text-ink-2">
            Don't see what you need listed? Our experts respond promptly with the quote you
            need — and we rent far more than cameras, from lenses to AV gear like monitors
            and computers for all of your post-production needs.
          </p>
        </div>
        <div class="reveal">
          <h2 class="display-sub text-lg">Studio camera rentals you can trust</h2>
          <p class="mt-4 max-w-[62ch] text-[0.9375rem] leading-relaxed text-ink-2">
            Every unit is meticulously checked so all elements are included and performing to
            the brand's standards — then packed in a custom box per model for fast, safe
            shipping. That's why 96% of our clients rent again.
          </p>
        </div>
        <div class="reveal lg:col-span-2">
          <h2 class="display-sub text-lg">4K camera chain rentals for event recording</h2>
          <p class="mt-4 max-w-[70ch] text-[0.9375rem] leading-relaxed text-ink-2">
            Our 4K Panasonic full camera chains are packaged and prepped for delivery so your
            event executes with confidence — Fujinon 20× lens and Sachtler V-18 tripod
            included. We understand time sensitivity: no waiting, no last-minute surprises.
          </p>
        </div>
      </div>

      <ul class="reveal mt-12 flex flex-wrap items-center gap-x-8 gap-y-3 border-t border-line pt-8" aria-label="Camera brands we carry">
        {['Panasonic', 'Canon', 'Fujinon', 'GoPro', 'Insta360', 'Sachtler', 'Vinten'].map((brand) => (
          <li class="mono-label text-ink-3">{brand}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="mx-auto max-w-[1440px] px-5 py-16 lg:px-10 lg:py-24">
    <div class="grid gap-10 lg:grid-cols-[1fr_1.6fr] lg:gap-20">
      <div class="reveal">
        <h2 class="display text-[clamp(1.75rem,3.5vw,2.75rem)]">Camera rental FAQs</h2>
        <p class="mt-4 max-w-[36ch] text-[0.9375rem] leading-relaxed text-ink-3">
          Straight answers from the rental desk. Anything else — call {SITE.phone}.
        </p>
      </div>
      <div class="reveal divide-y divide-line border-y border-line">
        {faqs.map((f) => (
          <details class="faq group py-1">
            <summary class="flex items-center justify-between gap-6 py-4 text-left text-base font-semibold lg:text-lg">
              {f.q}
              <svg class="faq-icon h-4 w-4 flex-none text-ink-3" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.4" />
              </svg>
            </summary>
            <div class="faq-body">
              <div>
                <p class="max-w-[68ch] pb-5 text-[0.9375rem] leading-relaxed text-ink-2">{f.a}</p>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="border-t border-line bg-ink text-bg">
    <div class="mx-auto flex max-w-[1440px] flex-col items-start justify-between gap-8 px-5 py-16 lg:flex-row lg:items-center lg:px-10">
      <div>
        <p class="mono-label mb-3 flex items-center gap-2 text-muted-dark"><span class="tally" aria-hidden="true"></span>Same-day response on every request</p>
        <h2 class="display text-[clamp(1.75rem,4vw,3rem)]">Spec your camera package</h2>
      </div>
      <button type="button" class="bg-bg px-7 py-4 text-sm font-semibold text-ink transition-colors hover:bg-signal hover:text-white" data-drawer-open>
        Review quote list
      </button>
    </div>
  </section>
</Base>
