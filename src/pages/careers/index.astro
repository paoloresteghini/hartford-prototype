---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../data/catalog.js';

// Live /careers/ copy, verbatim.
const intro =
  'If you’re interested in growing and advancing your career in the information technology industry, we’d like to meet you. Our team environment is a great place for you to be part of something that you help create. We’ll provide the support and resources you need to be successful.';
const benefitsLine =
  'Besides working with the latest technology, we offer competitive salaries and a comprehensive benefits plan that includes; medical, dental, paid time off, paid holidays, 401K and more.';
const locationsLine = 'We have offices in Chicago, Los Angeles, New York and Washington, DC that have immediate needs.';

const benefits = ['Medical', 'Dental', 'Paid time off', 'Paid holidays', '401K', 'And more'];

const roles = [
  {
    title: 'Audio Visual Technician',
    summary: 'In this role you will check, maintain and prepare audio visual equipment.',
