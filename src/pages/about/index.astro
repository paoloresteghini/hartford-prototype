---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { SITE, u } from '../../data/catalog.js';

const [products, cities] = await Promise.all([
  getCollection('products'),
  getCollection('cities'),
]);
const fleetCount = products.length;
const years = new Date().getFullYear() - 1991;

const depotCity = (token) => cities.find((c) => c.data.cityToken === token)?.data ?? null;
const depots = [
  { name: 'Las Vegas', addr: '4065 W Mesa Vista Ave, Suite C', state: 'Nevada', city: depotCity('las-vegas-nv') },
  { name: 'Arlington Heights', addr: '3 W College Drive', state: 'Illinois · Chicago metro', city: depotCity('chicago-il') },
  { name: 'Orlando', addr: '9535 Satellite Boulevard, Suite 300', state: 'Florida', city: depotCity('orlando-fl') },
];

const WP = 'https://hartfordrents.com/wp-content/uploads';
// Full "Who We Are" bios from the live About page, in its order.
const team = [
  {
    name: 'Anthony R. Graffia',
    role: 'Co-CEO',
    img: `${WP}/2020/02/pageImage-AnthonyG.jpg`,
    paras: [
      'Tony co-founded HTR in 1991 and serves as its co-CEO. From 1978 through 2005, he started, served as Chairman, and then sold one of the largest computer leasing companies in the Midwest, and he still serves as Chairman of several successor technology companies. From 1973 to 1978, Tony was Treasurer of Mutual Leasing Associates, a Chicago-based regional leasing company, and prior to that was a staff auditor with Grant Thornton. He is a Certified Public Accountant.',
      'His vast experience in the manufacturing and marketing of technology products provides HTR with extraordinary leadership, financial discipline and creativity in analyzing and structuring sophisticated solutions for our customers.',
    ],
  },
  {
    name: 'John B. Ward',
    role: 'Co-CEO',
    img: `${WP}/2020/02/pageImage-JohnW.jpg`,
    paras: [
      'As co-founder and co-CEO, John has invested 40 years in being an entrepreneur. During his career, he has started five companies and served on numerous corporate, university, association and charitable boards. Currently Hartford benefits from his focus on sales and customer service and his unwavering attention to detail. His broad industry knowledge has helped shape Hartford into an organization that offers not only the best technology rental equipment in the industry but also the most attentive service.',
    ],
    quote: 'Think like your customer’s partner, not just his supplier. That’s why we’re in business.',
  },
  {
    name: 'Mark Ferro',
    role: 'Regional Sales Manager',
    img: `${WP}/2020/02/pageImage-MarkF.jpg`,
    paras: [
      'Mark has an extensive technical background, loves solving problems, and brings 17 years of experience in providing total solutions to all types of businesses for short-term rental projects. After a nine-year stint opening and then running the Washington DC office for a publicly held competitor, Mark opened HTR’s Washington DC office. The quintessential entrepreneurial manager, Mark leads from the trenches with an accomplished and experienced team committed to making sure your next short-term project is a success.',
      'Problems, obstacles, an upcoming project where you’re not sure what you need? No problem. Mark is the consummate idea man who thrives on the challenges that complex events and short-term rental projects sometimes bring.',
    ],
  },
  {
    name: 'Dan Kallen',
    role: 'Vice President of Sales',
    img: `${WP}/2020/02/pageImage-DanK.jpg`,
    paras: [
      'Dan brings over 20 years of sales and expert project management to your doorstep. After working for NBC for five years, Dan joined Hartford’s Chicago office. During his ten years with Hartford, he has structured complex equipment, audio visual and communications packages for large trade show events, Fortune 500 companies, and lots and lots of much smaller organizations. He currently serves as President of the industry’s largest trade association, the International Technology Rental Association.',
      'Whether you need a single laptop or on-site project management at a large event, Dan will give you his full attention to ensure every detail goes as smoothly as possible. Plain and simple, customer service is the single most important aspect of Dan’s job.',
    ],
  },
  {
    name: 'Peter Kutrumanes',
    role: 'General Manager',
    img: `${WP}/2020/02/pageImage-PeterK.jpg`,
    paras: [
      'Pete brings over 18 years of experience in IT and AV related projects. Prior to joining HTR, Peter was an assistant trader at Comdisco, one of the largest IT service and leasing companies in the world. He then joined ICC Enterprises as Vice President and Director of Operations, where he was instrumental in growing it into one of the country’s largest IT and A/V rental companies. He has been with Hartford for over a dozen years.',
      'Such extensive, hands-on experience has helped him be sensitive to the needs of our clients and fully comprehend the complex business-related issues that are part of our industry. In the small amount of time we let him out of the office, Pete volunteers with several feed-the-poor organizations and helps coach youth basketball.',
    ],
  },
];

const values = [
  { title: 'Integrity', text: 'The highest standards of business ethics, on every order and every invoice.' },
  { title: 'Service excellence', text: 'The level of service we would demand for ourselves — before, during and after the event.' },
  { title: 'Teamwork', text: 'Shared, collective responsibility for every rental that leaves a depot.' },
  { title: 'Innovation', text: 'Continuous improvement in the fleet, the process and the technology behind both.' },
  { title: 'Economic value', text: 'Excellent value for clients while meeting our obligations as a business.' },
];

// Hero depot line — geography, not chronology (the timeline lives in the
// "signal path" section below). Last node is "live" (red tally).
const ledger = [
  { year: 'Chicago', label: '3 W College Drive, Arlington Heights' },
  { year: 'Las Vegas', label: '4065 W Mesa Vista Ave' },
  { year: 'Orlando', label: '9535 Satellite Boulevard' },
  { year: 'Nationwide', label: 'Overnight shipping, both ways', live: true },
];

const stats = [
  { n: years, suffix: '', label: 'Years in rental' },
  { n: fleetCount, suffix: '', label: 'Products in fleet' },
  { n: 50, suffix: '', label: 'States served' },
  { n: null, display: '24/7', label: 'Technical support' },
];

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Hartford Technology Rentals',
  url: `${SITE.url}/about/`,
  mainEntity: {
    '@type': 'Organization',
    name: SITE.legal,
    url: SITE.url,
    foundingDate: '1991',
    founder: [
      { '@type': 'Person', name: 'Anthony R. Graffia' },
      { '@type': 'Person', name: 'John B. Ward' },
    ],
    slogan: 'Not just equipment',
    address: depots.map((d) => ({ '@type': 'PostalAddress', streetAddress: d.addr, addressLocality: d.name, addressCountry: 'US' })),
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${SITE.url}/about/` },
  ],
};
---

<Base
  title="About Hartford Technology Rentals | Est. 1991 — Not Just Equipment"
  description="Founded in 1991 by two financial guys with 80 years of combined experience, Hartford Technology Rentals grew into a top-5 US AV and computing rental house — three depots, 50 states, 24/7 technicians. It's really service that we sell."
  schema={[breadcrumbSchema, aboutSchema]}
>
  <!-- ============ HERO — the company line ============ -->
  <section class="border-b border-line bg-paper-dark text-bg">
    <div class="mx-auto max-w-[1440px] px-5 pb-12 pt-14 lg:px-10 lg:pb-16 lg:pt-24">
      <p class="mono-label flex items-center gap-2 text-muted-dark">
        <span class="tally" aria-hidden="true"></span>Est. 1991 · Chicago — Las Vegas — Orlando
      </p>
      <h1 class="display hero-line mt-6 text-[clamp(2.75rem,7.5vw,6rem)]">Not just equipment</h1>
      <div class="mt-9 flex flex-wrap items-end justify-between gap-x-16 gap-y-8">
        <p class="hero-line max-w-[46ch] text-base leading-relaxed text-muted-dark lg:text-lg" style="--hl-delay: 90ms">
          “Even though we all spend the better part of each day talking, thinking and living
          technology rental equipment, it’s really service that we sell.”
        </p>
        <div class="hero-line flex flex-wrap items-center gap-5" style="--hl-delay: 160ms">
          <button type="button" class="bg-bg px-7 py-4 text-sm font-semibold text-ink transition-colors hover:bg-signal hover:text-white" data-drawer-open>
            Work with us
          </button>
          <a href={SITE.phoneHref} class="mono-label link-draw text-muted-dark">{SITE.phone} · 24/7</a>
        </div>
      </div>

      <!-- the ledger: 1978 → today, jumps to the full story -->
      <a
        href="#depots-heading"
        class="hero-ledger group relative mt-16 block pt-8 lg:mt-24"
        aria-label="Three depots, nationwide overnight — jump to depot details"
      >
        <span class="ledger-rule absolute left-0 top-0 hidden h-px w-full origin-left bg-line-dark transition-colors duration-300 group-hover:bg-muted-dark sm:block" aria-hidden="true"></span>
        <span class="grid grid-cols-2 gap-x-6 gap-y-10 sm:grid-cols-4">
          {ledger.map((node, i) => (
            <span class="ledger-node relative block" style={`--ln-delay: ${240 + i * 110}ms`}>
              <span
                class:list={[
                  'mb-3 block h-[7px] w-[7px] transition-transform duration-300 group-hover:scale-125 sm:absolute sm:-top-8 sm:left-0 sm:mb-0 sm:-translate-y-1/2',
                  node.live ? 'tally' : 'rounded-full bg-muted-dark',
                ]}
                aria-hidden="true"
              ></span>
              <span class="mono-label block text-bg">{node.year}</span>
              <span class="mt-1.5 block text-sm leading-snug text-muted-dark transition-colors duration-300 group-hover:text-bg">{node.label}</span>
            </span>
          ))}
          <span class="mono-label pointer-events-none absolute -top-8 right-0 hidden -translate-y-1/2 items-center gap-2 text-muted-dark opacity-0 transition-opacity duration-300 group-hover:opacity-100 sm:flex">
            The depots ↓
          </span>
        </span>
      </a>
    </div>
  </section>

  <!-- ============ STORY ============ -->
  <section class="border-b border-line">
    <div class="mx-auto grid max-w-[1440px] gap-10 px-5 py-14 lg:grid-cols-[1fr_1.4fr] lg:gap-20 lg:px-10 lg:py-20">
      <h2 class="display reveal text-[clamp(1.65rem,3.2vw,2.5rem)]">Two financial guys and a service obsession</h2>
      <div class="reveal max-w-[66ch] space-y-4 text-[0.9375rem] leading-relaxed text-ink-2">
        <p>
          Hartford Technology Rental was founded in 1991 by a couple of financial guys who really
          understand customer service and who have spent 80 years between them exceeding their
          customers’ expectations. We’ve surrounded ourselves with a team of extraordinary people
          who share our two founders’ vision of caring about customers and providing first-class
          technology rental products and service.
        </p>
        <p>
          We’ve got a saying: even though we all spend the better part of each day talking,
          thinking and living technology rental equipment, it’s really service that we sell.
          That’s where our tag line comes from — “Not just equipment.”
        </p>
        <p>
          Our job is to make your life easier — at least in the area of technology. We provide
          technology rental equipment, lots of it, and we make sure it’s new, well cared-for and
          from industry-leading manufacturers. But more importantly, we’ll help you make it work
          for your event, conference or office. We have a passion for details and will execute
          flawlessly: at all levels of our company, we act like partners and think like innovators.
        </p>
        <p>
          Oh, and did we mention that we really like what we do?
        </p>
      </div>
    </div>
  </section>

  <!-- ============ VALUES ============ -->
  <section class="border-b border-line bg-paper-dark text-bg">
    <div class="mx-auto max-w-[1440px] px-5 py-16 lg:px-10 lg:py-24">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <h2 class="display reveal max-w-xl text-[clamp(1.75rem,4vw,3rem)]">Five principles, since day one</h2>
        <p class="mono-label reveal text-muted-dark">The operating standard</p>
      </div>
      <ul class="mt-12 grid gap-px overflow-hidden border border-line-dark/60 bg-line-dark/60 sm:grid-cols-2 lg:grid-cols-5" role="list">
        {values.map((v) => (
          <li class="value-cell reveal bg-paper-dark p-7 lg:p-8" tabindex="0">
            <span class="tally value-tick" aria-hidden="true"></span>
            <p class="display-sub mt-4 text-base">{v.title}</p>
            <p class="value-text mt-3 text-sm leading-relaxed text-muted-dark">{v.text}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============ WHO WE ARE ============ -->
  <section class="border-b border-line bg-surface/60">
    <div class="mx-auto max-w-[1440px] px-5 py-14 lg:px-10 lg:py-20">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <h2 class="display reveal text-[clamp(1.65rem,3.2vw,2.5rem)]">The people on the other end of the phone</h2>
        <p class="mono-label reveal text-ink-3">Who we are</p>
      </div>
      <ol class="mt-6" role="list">
        {team.map((m, i) => (
          <li class="reveal border-t border-line py-10 first:mt-4 lg:py-14">
            <div class={`grid gap-8 lg:grid-cols-[280px_1fr] lg:gap-16 ${i % 2 === 1 ? 'lg:[direction:rtl]' : ''}`}>
              <div class="lg:[direction:ltr]">
                <div class="team-card relative w-full max-w-[280px] overflow-hidden border border-line bg-bg">
                  <img
                    src={m.img}
                    alt={`${m.name}, ${m.role}`}
                    class="team-photo aspect-[4/5] w-full object-cover"
                    loading="lazy"
                    width="440" height="550"
                  />
                  <p class="mono-label border-t border-line px-4 py-2.5 text-ink-3">{m.role}</p>
                </div>
              </div>
              <div class="max-w-[66ch] lg:[direction:ltr]">
                <h3 class="display-sub text-xl text-ink">{m.name}</h3>
                <div class="mt-5 space-y-4 text-[0.9375rem] leading-relaxed text-ink-2">
                  {m.paras.map((p) => (
                    <p>{p}</p>
                  ))}
                </div>
                {m.quote && (
                  <blockquote class="mt-6 border-t border-line pt-5">
                    <p class="flex items-start gap-3 text-lg font-medium leading-snug text-ink">
                      <span class="tally mt-2 flex-none" aria-hidden="true"></span>
                      “{m.quote}”
                    </p>
                  </blockquote>
                )}
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============ DEPOTS ============ -->
  <section class="border-b border-line bg-surface/60">
    <div class="mx-auto max-w-[1440px] px-5 py-14 lg:px-10 lg:py-20">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <h2 id="depots-heading" class="display-sub reveal scroll-mt-28 text-lg text-ink">Three depots. Any venue, overnight.</h2>
        <p class="mono-label reveal text-ink-3">Plus a Washington DC office</p>
      </div>
      <ul class="mt-8 grid gap-4 md:grid-cols-3" role="list">
        {depots.map((d) => (
          <li class="depot-card reveal group relative overflow-hidden border border-line bg-ink text-bg">
            {d.city?.image && (
              <img src={d.city.image} alt="" class="depot-img absolute inset-0 h-full w-full object-cover opacity-50" loading="lazy" width="600" height="400" />
            )}
            <div class="relative flex min-h-[240px] flex-col justify-end bg-gradient-to-t from-ink via-ink/60 to-transparent p-6">
              <p class="mono-label flex items-center gap-2 text-muted-dark"><span class="tally" aria-hidden="true"></span>{d.state}</p>
              <h3 class="display-sub mt-2 text-lg">{d.name}</h3>
              <p class="mt-1.5 font-mono text-xs text-muted-dark">{d.addr}</p>
              {d.city && (
                <a href={u(d.city.url)} class="link-draw mt-4 inline-block text-sm font-medium text-bg after:absolute after:inset-0">
                  Rentals in {d.name} →
                </a>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============ LIVE STATS ============ -->
  <section class="border-b border-line">
    <div class="mx-auto grid max-w-[1440px] grid-cols-2 gap-px overflow-hidden border-x border-line bg-line lg:grid-cols-4">
      {stats.map((s) => (
        <div class="reveal bg-bg px-6 py-10 text-center lg:py-14">
          <p class="stat-n font-mono text-3xl font-medium text-ink lg:text-4xl" data-count={s.n ?? undefined}>
            {s.n === null ? s.display : '0'}
          </p>
          <p class="mono-label mt-3 text-ink-3">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="bg-ink text-bg">
    <div class="mx-auto flex max-w-[1440px] flex-col items-start justify-between gap-8 px-5 py-16 lg:flex-row lg:items-center lg:px-10">
      <div>
        <p class="mono-label mb-3 flex items-center gap-2 text-muted-dark"><span class="tally" aria-hidden="true"></span>Same-day response on every request</p>
        <h2 class="display text-[clamp(1.75rem,4vw,3rem)]">Put 35 years to work</h2>
      </div>
      <button type="button" class="bg-bg px-7 py-4 text-sm font-semibold text-ink transition-colors hover:bg-signal hover:text-white" data-drawer-open>
        Review quote list
      </button>
    </div>
  </section>
</Base>

<style>
  /* ---------- hero: staggered load + ledger draw (enhance, never gate) ---------- */
  .hero-line {
    animation: hero-rise 0.7s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) both;
    animation-delay: var(--hl-delay, 0ms);
  }
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: none; }
  }
  .ledger-rule {
    animation: ledger-draw 1s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) 0.2s both;
  }
  @keyframes ledger-draw {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }
  .ledger-node {
    animation: hero-rise 0.6s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) both;
    animation-delay: var(--ln-delay, 0ms);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-line,
    .ledger-rule,
    .ledger-node {
      animation: none;
    }
  }

  /* ---------- values: tick lights + description raises on hover/focus ---------- */
  .value-cell { outline: none; transition: background-color 0.25s var(--ease-out-quart); }
  .value-tick { opacity: 0.25; transition: opacity 0.25s ease; }
  .value-cell:hover, .value-cell:focus-visible {
    background-color: oklch(0.24 0.008 260);
  }
  .value-cell:hover .value-tick, .value-cell:focus-visible .value-tick { opacity: 1; }
  .value-cell:focus-visible { outline: 2px solid var(--color-signal); outline-offset: -2px; }
  @media (min-width: 1024px) {
    .value-text {
      opacity: 0.55;
      transform: translateY(4px);
      transition: opacity 0.3s var(--ease-out-quart), transform 0.3s var(--ease-out-quart);
    }
    .value-cell:hover .value-text, .value-cell:focus-visible .value-text {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ---------- team: monochrome portraits, color on hover ---------- */
  .team-photo {
    filter: grayscale(1) contrast(1.05);
    transition: filter 0.4s var(--ease-out-quart), transform 0.6s var(--ease-out-expo);
  }
  .team-card:hover .team-photo, .team-card:focus-within .team-photo {
    filter: grayscale(0);
    transform: scale(1.03);
  }

  /* ---------- depots: image lifts on hover ---------- */
  .depot-img { transition: opacity 0.35s ease, transform 0.7s var(--ease-out-expo); }
  .depot-card:hover .depot-img, .depot-card:focus-within .depot-img {
    opacity: 0.72;
    transform: scale(1.04);
  }

  @media (prefers-reduced-motion: reduce) {
    .team-photo, .depot-img, .value-text { transition: none; }
  }
</style>

<script>
  // Count-up stats: fires once when the band scrolls into view.
  // Reduced motion (or no IO) = final values immediately.
  const els = [...document.querySelectorAll('.stat-n[data-count]')] as HTMLElement[];
  const setFinal = () => els.forEach((el) => (el.textContent = el.dataset.count ?? ''));
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduced || !('IntersectionObserver' in window) || els.length === 0) {
    setFinal();
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          io.unobserve(entry.target);
          const el = entry.target as HTMLElement;
          const target = Number(el.dataset.count);
          const t0 = performance.now();
          const dur = 1100;
          const tick = (t: number) => {
            const p = Math.min(1, (t - t0) / dur);
            const eased = 1 - Math.pow(1 - p, 4); // ease-out-quart
            el.textContent = String(Math.round(target * eased));
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        });
      },
      { threshold: 0.4 }
    );
    els.forEach((el) => io.observe(el));
  }
</script>
