---
// src/pages/locations/[slug].astro
// Single route serving all three location page kinds: 7,502 matrix pages
// (category × state/city), 51 state pages, 191 city pages. All groupings
// needed by the page components (siblings, "more rentals", category
// indexes, city grids) are precomputed ONCE here as plain Maps/objects and
// handed down via props — the components never re-filter the full
// locationPages collection per page (that would be O(n^2) over 7,502 rows).
import { getCollection } from 'astro:content';
import LocationMatrixPage from '../../components/LocationMatrixPage.astro';
import StatePage from '../../components/StatePage.astro';
import CityPage from '../../components/CityPage.astro';

export async function getStaticPaths() {
  // Astro hoists getStaticPaths into an isolated scope (only imports carry
  // over — see the removed interim route's comment), so these constants
  // must live inside the function, not as sibling module-level consts.
  const MORE_RENTALS_CAP = 12;
  const PRODUCT_GRID_CAP = 8;
  const [matrixEntries, stateEntries, cityEntries, categoryEntries, productEntries] = await Promise.all([
    getCollection('locationPages'),
    getCollection('states'),
    getCollection('cities'),
    getCollection('categories'),
    getCollection('products'),
  ]);

  const matrixRows = matrixEntries.map((e) => e.data);
  const stateRows = stateEntries.map((e) => e.data);
  const cityRows = cityEntries.map((e) => e.data);
  const categoryRows = categoryEntries.map((e) => e.data);
  const productRows = productEntries.map((e) => e.data);

  if (matrixRows.length === 0 && stateRows.length === 0 && cityRows.length === 0) return [];

  const categoryById = new Map(categoryRows.map((c) => [c.id, c]));
  const productById = new Map(productRows.map((p) => [p.id, p]));
  const cityByToken = new Map(cityRows.map((c) => [c.cityToken, c]));
  const stateByPath = new Map(stateRows.map((s) => [s.path, s]));

  // ---- one pass over the 7,502 matrix rows to build every grouping needed ----
  const byCatState = new Map(); // `${categorySlug}|${stateSlug}` -> rows[]  (siblings)
  const byStateLevel = new Map(); // stateSlug -> state-level rows[]  ("more rentals" + state category index)
  const byCityToken = new Map(); // cityToken -> city-level rows[]   ("more rentals" + city matrix links)
  const cityTokensByState = new Map(); // stateSlug -> Set(cityToken)  (state city grid)
  const rowMeta = new Map(); // path -> { cityTok }

  for (const row of matrixRows) {
    const cityTok = row.isStateLevel ? null : row.path.replace(`${row.categorySlug}-`, '');
    rowMeta.set(row.path, { cityTok });

    const csKey = `${row.categorySlug}|${row.stateSlug}`;
    if (!byCatState.has(csKey)) byCatState.set(csKey, []);
    byCatState.get(csKey).push(row);

    if (row.isStateLevel) {
      if (!byStateLevel.has(row.stateSlug)) byStateLevel.set(row.stateSlug, []);
      byStateLevel.get(row.stateSlug).push(row);
    } else {
      if (!byCityToken.has(cityTok)) byCityToken.set(cityTok, []);
      byCityToken.get(cityTok).push(row);

      if (!cityTokensByState.has(row.stateSlug)) cityTokensByState.set(row.stateSlug, new Set());
      cityTokensByState.get(row.stateSlug).add(cityTok);
    }
  }

  const toProductItems = (cat) => {
    if (!cat) return [];
    return cat.productIds
      .slice(0, PRODUCT_GRID_CAP)
      .map((id) => productById.get(id))
      .filter(Boolean)
      .map((p) => ({
        sku: p.id,
        brand: '',
        name: p.name.replace(/\s*Rentals?$/i, ''),
        img: p.image || '/img/camera-hero.jpg',
        blurb: p.blurb,
        type: 'all',
        typeLabel: cat.name,
        href: p.url,
        featured: false,
      }));
  };

  // ---- matrix pages ----
  const matrixPaths = matrixRows.map((row) => {
    const { cityTok } = rowMeta.get(row.path);
    const cat = row.categoryId ? categoryById.get(row.categoryId) ?? null : null;
    const items = toProductItems(cat);

    const csKey = `${row.categorySlug}|${row.stateSlug}`;
    const siblings = (byCatState.get(csKey) || []).filter((r) => r.path !== row.path);

    const moreRentalsPool = row.isStateLevel ? byStateLevel.get(row.stateSlug) || [] : byCityToken.get(cityTok) || [];
    const moreRentals = moreRentalsPool.filter((r) => r.path !== row.path).slice(0, MORE_RENTALS_CAP);

    const state = stateByPath.get(row.stateSlug) ?? null;
    const city = row.isStateLevel ? null : cityByToken.get(cityTok) ?? null;

    return {
      params: { slug: row.path },
      props: { kind: 'matrix', row, cat, items, siblings, moreRentals, state, city },
    };
  });

  // ---- state pages ----
  const statePaths = stateRows.map((state) => {
    const tokens = cityTokensByState.get(state.path) || new Set();
    const cityList = [...tokens].map((t) => cityByToken.get(t)).filter(Boolean);
    const categoryIndex = byStateLevel.get(state.path) || [];
    return {
      params: { slug: state.path },
      props: { kind: 'state', row: state, cityList, categoryIndex },
    };
  });

  // ---- city pages ----
  const cityPaths = cityRows.map((city) => {
    const matrixLinks = byCityToken.get(city.cityToken) || [];
    return {
      params: { slug: city.path },
      props: { kind: 'city', row: city, matrixLinks },
    };
  });

  return [...matrixPaths, ...statePaths, ...cityPaths];
}

const props = Astro.props;
---
{props.kind === 'matrix' && (
  <LocationMatrixPage
    row={props.row}
    cat={props.cat}
    items={props.items}
    siblings={props.siblings}
    moreRentals={props.moreRentals}
    state={props.state}
    city={props.city}
  />
)}
{props.kind === 'state' && <StatePage row={props.row} cityList={props.cityList} categoryIndex={props.categoryIndex} />}
{props.kind === 'city' && <CityPage row={props.row} matrixLinks={props.matrixLinks} />}
