---
// State-level location hub (51 of these): one per U.S. state (+DC). Shows the
// state's cities and its 31-category matrix index. `cityList` and
// `categoryIndex` are precomputed once in src/pages/locations/[slug].astro.
import Base from '../layouts/Base.astro';
import { SITE, u } from '../data/catalog.js';

interface Props {
  row: any;
  cityList: any[];
  categoryIndex: any[];
}

const { row, cityList, categoryIndex } = Astro.props;

const displayH1 = `${row.name} Audio Visual & Technology Rentals`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE.url}/locations/` },
    { '@type': 'ListItem', position: 3, name: row.name, item: `${SITE.url}${row.url}` },
  ],
};
---

<Base
  title={`${displayH1} | Hartford Technology Rentals`}
  description={`Audio visual and technology equipment rentals across ${row.name} — fast delivery, on-site setup, and 24/7 support.`}
  schema={[breadcrumbSchema]}
>
  <section class="border-b border-line">
    <div class="mx-auto max-w-[1440px] px-5 pt-8 lg:px-10">
      <nav aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-2 font-mono text-xs text-ink-3">
          <li><a href={u('/')} class="link-draw hover:text-ink">Home</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-ink">{row.name}</li>
        </ol>
      </nav>

      <div class="grid gap-10 pb-12 pt-10 lg:grid-cols-[1.5fr_1fr] lg:gap-16 lg:pb-16">
        <div>
          <p class="mono-label flex items-center gap-2 text-ink-3"><span class="tally" aria-hidden="true"></span>Statewide service</p>
          <h1 class="display mt-4 max-w-4xl text-[clamp(2rem,5vw,3.75rem)]">{displayH1}</h1>
          {row.contentHtml && (
            <div class="prose-seo mt-6 max-w-[62ch] text-[0.9375rem] leading-relaxed text-ink-2" set:html={row.contentHtml} />
          )}
          <div class="mt-8 flex flex-wrap items-center gap-5">
            <button type="button" class="bg-ink px-6 py-3.5 text-sm font-semibold text-bg transition-colors hover:bg-signal-strong" data-drawer-open>
              Request a quote
            </button>
            <a href={SITE.phoneHref} class="mono-label link-draw text-ink-2">{SITE.phone} · 24/7</a>
          </div>
        </div>
        {row.image && (
          <div class="reveal-img relative hidden min-h-[280px] overflow-hidden lg:block">
            <img src={row.image} alt={row.name} class="absolute inset-0 h-full w-full object-cover" />
          </div>
        )}
      </div>
    </div>
  </section>

  {cityList.length > 0 && (
    <section class="mx-auto max-w-[1440px] px-5 py-12 lg:px-10 lg:py-16">
      <h2 class="display-sub text-lg">Cities we serve in {row.name}</h2>
      <div class="mt-8 grid grid-cols-[repeat(auto-fill,minmax(220px,1fr))] gap-4">
        {cityList.map((city) => (
          <a href={u(city.url)} class="group block border border-line bg-bg transition-colors hover:border-ink">
            {city.image && (
              <div class="relative aspect-[4/3] overflow-hidden">
                <img src={city.image} alt={city.name} loading="lazy" class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
              </div>
            )}
            <p class="p-4 text-sm font-semibold">{city.name}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  {categoryIndex.length > 0 && (
    <section class="border-t border-line bg-surface/60">
      <div class="mx-auto max-w-[1440px] px-5 py-12 lg:px-10 lg:py-16">
        <h2 class="display-sub text-lg">Rentals available across {row.name}</h2>
        <ul class="mt-6 grid grid-cols-[repeat(auto-fill,minmax(240px,1fr))] gap-2">
          {categoryIndex.map((c) => (
            <li>
              <a href={u(`/locations/${c.path}/`)} class="block border border-line bg-bg px-4 py-2 text-sm font-medium transition-colors hover:border-ink">
                {c.h1}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="border-t border-line bg-ink text-bg">
    <div class="mx-auto flex max-w-[1440px] flex-col items-start justify-between gap-8 px-5 py-16 lg:flex-row lg:items-center lg:px-10">
      <div>
        <p class="mono-label mb-3 flex items-center gap-2 text-muted-dark"><span class="tally" aria-hidden="true"></span>Same-day response on every request</p>
        <h2 class="display text-[clamp(1.75rem,4vw,3rem)]">Technology rentals across {row.name}, sorted</h2>
      </div>
      <button type="button" class="bg-bg px-7 py-4 text-sm font-semibold text-ink transition-colors hover:bg-signal hover:text-white" data-drawer-open>
        Review quote list
      </button>
    </div>
  </section>
</Base>
