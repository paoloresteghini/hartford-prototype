---
// City-level location hub (191 of these): one per served city, linking out
// to that city's 31 category matrix pages. `matrixLinks` is precomputed once
// in src/pages/locations/[slug].astro (keyed by city token, not a per-page
// filter over the full locationPages collection).
import Base from '../layouts/Base.astro';
import { SITE, u } from '../data/catalog.js';

interface Props {
  row: any;
  matrixLinks: any[];
}

const { row, matrixLinks } = Astro.props;

// Bare city names ("Orlando") get the generic suffix; if upstream ever ships
// a name that already reads as a full title (contains "Rental"), keep it.
const displayH1 = /rental/i.test(row.name) ? row.name : `${row.name} Technology Rentals`;

const first = matrixLinks[0];
const stateCrumb = first ? { name: first.state, url: `/locations/${first.stateSlug}/` } : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Locations', item: `${SITE.url}/locations/` },
    ...(stateCrumb
      ? [{ '@type': 'ListItem', position: 3, name: stateCrumb.name.split(',')[0], item: `${SITE.url}${stateCrumb.url}` }]
      : []),
    { '@type': 'ListItem', position: stateCrumb ? 4 : 3, name: row.name, item: `${SITE.url}${row.url}` },
  ],
};
---

<Base title={`${displayH1} | Hartford Technology Rentals`} description={row.metaDescription || `Technology and audio visual equipment rentals in ${row.name} — fast delivery, on-site setup, 24/7 support.`} schema={[breadcrumbSchema]}>
  <section class="border-b border-line">
    <div class="mx-auto max-w-[1440px] px-5 pt-8 lg:px-10">
      <nav aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-2 font-mono text-xs text-ink-3">
          <li><a href={u('/')} class="link-draw hover:text-ink">Home</a></li>
          <li aria-hidden="true">/</li>
          {stateCrumb && (
            <>
              <li><a href={u(stateCrumb.url)} class="link-draw hover:text-ink">{stateCrumb.name.split(',')[0]}</a></li>
              <li aria-hidden="true">/</li>
            </>
          )}
          <li aria-current="page" class="text-ink">{row.name}</li>
        </ol>
      </nav>

      <div class="grid gap-10 pb-12 pt-10 lg:grid-cols-[1.5fr_1fr] lg:gap-16 lg:pb-16">
        <div>
          <p class="mono-label flex items-center gap-2 text-ink-3"><span class="tally" aria-hidden="true"></span>Local service</p>
          <h1 class="display mt-4 max-w-4xl text-[clamp(2rem,5vw,3.75rem)]">{displayH1}</h1>
          <div class="mt-8 flex flex-wrap items-center gap-5">
            <button type="button" class="bg-ink px-6 py-3.5 text-sm font-semibold text-bg transition-colors hover:bg-signal-strong" data-drawer-open>
              Request a quote
            </button>
            <a href={SITE.phoneHref} class="mono-label link-draw text-ink-2">{SITE.phone} · 24/7</a>
          </div>
        </div>
        {(row.image || row.image2) && (
          <div class="hidden gap-2 lg:grid lg:min-h-[280px] lg:grid-rows-2">
            {row.image && (
              <div class="reveal-img relative overflow-hidden">
                <img src={row.image} alt={row.name} class="absolute inset-0 h-full w-full object-cover" />
              </div>
            )}
            {row.image2 && (
              <div class="reveal-img relative overflow-hidden">
                <img src={row.image2} alt={row.name} class="absolute inset-0 h-full w-full object-cover" />
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  </section>

  {(row.contentHtml || row.descriptionHtml) && (
    <section class="mx-auto max-w-[1440px] px-5 py-12 lg:px-10 lg:py-16">
      {row.contentHtml && (
        <div class="prose-seo max-w-[74ch] text-[0.9375rem] leading-relaxed text-ink-2" set:html={row.contentHtml} />
      )}
      {row.descriptionHtml && (
        <div class="prose-seo mt-6 max-w-[74ch] text-[0.9375rem] leading-relaxed text-ink-2" set:html={row.descriptionHtml} />
      )}
    </section>
  )}

  {row.iframeHtml && (
    <section class="border-t border-line bg-surface/60">
      <div class="mx-auto max-w-[1440px] px-5 py-12 lg:px-10">
        <h2 class="display-sub text-lg">Delivery area</h2>
        <div class="reveal mt-6 overflow-hidden border border-line bg-bg p-4" set:html={row.iframeHtml} />
      </div>
    </section>
  )}

  {matrixLinks.length > 0 && (
    <section class="border-t border-line">
      <div class="mx-auto max-w-[1440px] px-5 py-12 lg:px-10 lg:py-16">
        <h2 class="display-sub text-lg">Rentals available in {row.name}</h2>
        <ul class="mt-6 grid grid-cols-[repeat(auto-fill,minmax(240px,1fr))] gap-2">
          {matrixLinks.map((m) => (
            <li>
              <a href={u(`/locations/${m.path}/`)} class="block border border-line px-4 py-2 text-sm font-medium transition-colors hover:border-ink">
                {m.category}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="border-t border-line bg-ink text-bg">
    <div class="mx-auto flex max-w-[1440px] flex-col items-start justify-between gap-8 px-5 py-16 lg:flex-row lg:items-center lg:px-10">
      <div>
        <p class="mono-label mb-3 flex items-center gap-2 text-muted-dark"><span class="tally" aria-hidden="true"></span>Same-day response on every request</p>
        <h2 class="display text-[clamp(1.75rem,4vw,3rem)]">Technology rentals in {row.name}, sorted</h2>
      </div>
      <button type="button" class="bg-bg px-7 py-4 text-sm font-semibold text-ink transition-colors hover:bg-signal hover:text-white" data-drawer-open>
        Review quote list
      </button>
    </div>
  </section>
</Base>
