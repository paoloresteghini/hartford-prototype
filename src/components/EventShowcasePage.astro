---
import Base from '../layouts/Base.astro';
import ProductCard from './ProductCard.astro';
import { SITE, u } from '../data/catalog.js';
import { parseEventBody, parsePillars } from '../lib/hubdb/event-showcase.js';

const { page, config, categories, products } = Astro.props;

const sections = parseEventBody(page.bodyHtml);
const zoneId = (label) => label.split('·')[1].trim().toLowerCase().replace(/\s+/g, '-');

const intro = sections[0] || { heading: page.h1, html: '' };
const whySection = sections.find((s) => /why|choose/i.test(s.heading));
const conclusion = sections.find((s) => /conclusion/i.test(s.heading));
const pillars = whySection ? parsePillars(whySection.html) : [];
const whyProse = whySection ? whySection.html.split(/<h3>/i)[0] : '';
const conclusionProse = conclusion ? conclusion.html : '';

const catBySlug = new Map(categories.map((c) => [c.slug, c]));
const productById = new Map(products.map((p) => [p.id, p]));

// Resolve each configured zone against the parsed sections + live catalog.
const zones = config.zones
  .map((z) => {
    const section = sections.find((s) => z.match.test(s.heading));
    if (!section) return null;
    const cats = z.cats.map((slug) => catBySlug.get(slug)).filter(Boolean);
    const items = cats
      .map((cat) => {
        const p = cat.productIds.map((id) => productById.get(id)).find((x) => x && x.image);
        if (!p) return null;
        return {
          sku: p.id,
          brand: '',
          name: p.name.replace(/\s*Rentals?$/i, ''),
          img: p.image,
          blurb: p.blurb,
          type: 'all',
          typeLabel: cat.name,
          href: u(p.url),
          featured: false,
        };
      })
      .filter(Boolean);
    return { ...z, section, cats, items };
  })
  .filter(Boolean);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: page.h1, item: `${SITE.url}${page.url}` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: page.h1,
  description: page.metaDescription,
  url: `${SITE.url}${page.url}`,
  provider: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  areaServed: 'US',
  serviceType: 'Event technology equipment rental',
};
---

<Base title={page.title || page.h1} description={page.metaDescription} schema={[breadcrumbSchema, serviceSchema]}>
  <!-- ============ HERO — venue plan, drawing no. 01 ============ -->
  <section class="relative overflow-hidden border-b border-line bg-paper-dark text-bg">
    <!-- blueprint grid -->
    <div class="bp-grid pointer-events-none absolute inset-0" aria-hidden="true"></div>

    <!-- venue plan drawing (decorative; callout links carry the semantics) -->
    <svg
      class="bp-plan pointer-events-none absolute inset-0 hidden h-full w-full lg:block"
      viewBox="0 0 1440 680"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
    >
      <defs>
        <pattern id="bp-hatch" width="8" height="8" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
          <line x1="0" y1="0" x2="0" y2="8" stroke="currentColor" stroke-width="1" />
        </pattern>
      </defs>
      <g stroke="currentColor" fill="none" stroke-width="1" class="text-muted-dark/60">
        <!-- stage + LED wall + podium (right half; left is reserved for the headline) -->
        <rect class="bp-draw" x="850" y="70" width="380" height="120" pathLength="1" />
        <rect x="860" y="80" width="360" height="24" fill="url(#bp-hatch)" class="bp-fade text-muted-dark/40" />
        <rect class="bp-fade" x="900" y="150" width="40" height="24" />
        <!-- breakout + expo rooms -->
        <rect class="bp-draw" x="650" y="80" width="160" height="110" stroke-dasharray="6 5" pathLength="1" style="--bp-delay: 350ms" />
        <rect class="bp-draw" x="1270" y="80" width="130" height="110" stroke-dasharray="6 5" pathLength="1" style="--bp-delay: 450ms" />
        <!-- FOH + check-in desk -->
        <rect class="bp-draw" x="960" y="540" width="120" height="50" pathLength="1" style="--bp-delay: 550ms" />
        <rect class="bp-draw" x="1250" y="470" width="150" height="60" pathLength="1" style="--bp-delay: 650ms" />
        <!-- PTZ camera positions -->
        <path class="bp-fade" d="M892 312 l16 0 l-8 -14 z" />
        <path class="bp-fade" d="M1032 332 l16 0 l-8 -14 z" />
        <path class="bp-fade" d="M1172 312 l16 0 l-8 -14 z" />
        <!-- delay speakers -->
        <circle class="bp-fade" cx="700" cy="330" r="5" />
        <circle class="bp-fade" cx="1360" cy="330" r="5" />
        <path class="bp-fade" d="M710 322 a12 12 0 0 1 0 16 M714 318 a18 18 0 0 1 0 24" stroke-width="0.75" />
        <path class="bp-fade" d="M1350 322 a12 12 0 0 0 0 16 M1346 318 a18 18 0 0 0 0 24" stroke-width="0.75" />
        <!-- audience seating -->
        <g class="bp-fade text-muted-dark/40">
          {Array.from({ length: 6 }, (_, row) =>
            Array.from({ length: 12 }, (_, col) => (
              <line
                x1={720 + col * 44}
                y1={280 + row * 38}
                x2={744 + col * 44}
                y2={280 + row * 38}
                stroke-width="2"
              />
            ))
          )}
        </g>
      </g>
      <!-- live tally on the center camera -->
      <circle cx="1040" cy="310" r="3.5" class="fill-signal" />
      <g class="fill-muted-dark/80 font-mono" font-size="11" letter-spacing="0.1em">
        <text x="1018" y="135">STAGE</text>
        <text x="988" y="572">FOH</text>
        <text x="1282" y="505">CHECK-IN</text>
        <text x="695" y="140">BREAKOUT</text>
        <text x="1318" y="140">EXPO</text>
      </g>
    </svg>

    <!-- zone callouts — real links into the page -->
    <div class="absolute inset-0 z-10 mx-auto hidden max-w-[1440px] lg:block" aria-label="Venue zones">
      {[
        { href: '#zone-main-stage', label: 'Zone · Main stage', pos: 'left-[60%] top-[4.5%]' },
        { href: '#zone-breakout-rooms', label: 'Zone · Breakout rooms', pos: 'left-[45%] top-[32%]' },
        { href: '#zone-expo-floor', label: 'Zone · Expo floor', pos: 'right-[3%] top-[4.5%]' },
        { href: '#zone-check-in', label: 'Zone · Check-in', pos: 'right-[3%] bottom-[34%]' },
      ].map((c) => (
        <a href={c.href} class={`bp-callout pointer-events-auto absolute flex items-center gap-2 ${c.pos}`}>
          <span class="tally" aria-hidden="true"></span>
          <span class="mono-label link-draw text-muted-dark transition-colors hover:text-bg">{c.label}</span>
        </a>
      ))}
    </div>

    <!-- drawing title block -->
    <div class="bp-fade-html absolute bottom-6 right-6 z-10 hidden text-right lg:block" aria-hidden="true">
      <div class="border border-line-dark/60">
        <p class="mono-label border-b border-line-dark/60 px-3 py-1.5 text-muted-dark">Hartford Technology Rentals</p>
        <p class="mono-label border-b border-line-dark/60 px-3 py-1.5 text-muted-dark">General session — plan view</p>
        <p class="mono-label px-3 py-1.5 text-muted-dark">Scale NTS · Sheet 01 · Full-venue kit</p>
      </div>
    </div>

    <div class="relative mx-auto flex min-h-[540px] max-w-[1440px] items-center px-5 pb-16 pt-14 lg:min-h-[660px] lg:px-10">
      <div class="max-w-[560px]">
        <p class="mono-label flex items-center gap-2 text-muted-dark">
          <span class="tally" aria-hidden="true"></span>Event production · Nationwide
        </p>
        <h1 class="display mt-5 text-[clamp(2.25rem,5.5vw,4.5rem)]">
          Best event equipment rentals
        </h1>
        <p class="mt-6 max-w-[46ch] text-base leading-relaxed text-muted-dark lg:text-lg">
          {page.metaDescription}
        </p>
        <div class="mt-9 flex flex-wrap items-center gap-5">
          <button type="button" class="bg-bg px-7 py-4 text-sm font-semibold text-ink transition-colors hover:bg-signal hover:text-white" data-drawer-open>
            Build your event quote
          </button>
          <a href={SITE.phoneHref} class="mono-label link-draw text-muted-dark">{SITE.phone} · 24/7</a>
        </div>
        <p class="mono-label mt-10 text-muted-dark">3 depot cities · 24/7 on-call technicians · 50 states served</p>
      </div>
    </div>
  </section>

  <!-- ============ INTRO ============ -->
  <section class="border-b border-line">
    <div class="mx-auto grid max-w-[1440px] gap-10 px-5 py-14 lg:grid-cols-[1fr_1.4fr] lg:gap-20 lg:px-10 lg:py-20">
      <h2 class="display reveal text-[clamp(1.65rem,3.2vw,2.5rem)]">{intro.heading}</h2>
      <div class="prose-seo reveal max-w-[68ch] text-[0.9375rem] leading-relaxed text-ink-2" set:html={intro.html} />
    </div>
  </section>

  <!-- ============ VENUE ZONES ============ -->
  {zones.map((zone, i) => (
    <section id={`zone-${zoneId(zone.label)}`} class={`scroll-mt-28 border-b border-line ${i % 2 === 1 ? 'bg-surface/60' : ''}`}>
      <div class="mx-auto max-w-[1440px] px-5 py-14 lg:px-10 lg:py-20">
        <div class={`grid gap-10 lg:grid-cols-[1fr_1.2fr] lg:gap-16 ${i % 2 === 1 ? 'lg:[direction:rtl]' : ''}`}>
          <div class="lg:[direction:ltr]">
            <p class="mono-label reveal flex items-center gap-2 text-ink-3">
              <span class="tally" aria-hidden="true"></span>{zone.label}
            </p>
            <h2 class="display-sub reveal mt-4 text-[clamp(1.35rem,2.6vw,1.9rem)] text-ink">{zone.section.heading}</h2>
            <div class="prose-seo reveal mt-6 max-w-[62ch] text-[0.9375rem] leading-relaxed text-ink-2" set:html={zone.section.html} />
            <div class="reveal mt-8 flex flex-wrap gap-2">
              {zone.cats.map((cat) => (
                <a href={u(cat.url)} class="border border-line bg-bg px-4 py-2 text-sm font-medium transition-colors hover:border-ink">
                  {cat.name} →
                </a>
              ))}
            </div>
          </div>
          <div class="lg:[direction:ltr]">
            <div class="grid grid-cols-2 gap-3">
              {zone.items.map((p, j) => (
                <div class="reveal">
                  <ProductCard product={p} eager={i === 0 && j < 2} />
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- ============ WHY HARTFORD — dark pillars ============ -->
  {whySection && (
    <section class="border-b border-line bg-paper-dark text-bg">
      <div class="mx-auto max-w-[1440px] px-5 py-16 lg:px-10 lg:py-24">
        <div class="grid gap-10 lg:grid-cols-[1.1fr_1fr] lg:gap-20">
          <h2 class="display reveal max-w-xl text-[clamp(1.75rem,4vw,3rem)]">{whySection.heading}</h2>
          <div class="prose-seo reveal self-center text-[0.9375rem] leading-relaxed text-muted-dark [&_strong]:text-bg" set:html={whyProse} />
        </div>
        {pillars.length > 0 && (
          <ul class="mt-12 grid gap-px overflow-hidden border border-line-dark/60 bg-line-dark/60 sm:grid-cols-2 lg:grid-cols-4">
            {pillars.map((p) => (
              <li class="reveal bg-paper-dark p-7 lg:p-8">
                <p class="display-sub text-base">{p.title}</p>
                <p class="mt-3 text-sm leading-relaxed text-muted-dark">{p.text}</p>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>
  )}

  <!-- ============ CONCLUSION + CTA ============ -->
  <section class="mx-auto max-w-[1440px] px-5 py-14 lg:px-10 lg:py-20">
    <div class="grid gap-10 lg:grid-cols-[1fr_1.4fr] lg:gap-20">
      <h2 class="display-sub reveal text-lg text-ink">Run the whole event on one quote</h2>
      <div class="prose-seo reveal max-w-[68ch] text-[0.9375rem] leading-relaxed text-ink-2" set:html={conclusionProse} />
    </div>
  </section>

  <section class="border-t border-line bg-ink text-bg">
    <div class="mx-auto flex max-w-[1440px] flex-col items-start justify-between gap-8 px-5 py-16 lg:flex-row lg:items-center lg:px-10">
      <div>
        <p class="mono-label mb-3 flex items-center gap-2 text-muted-dark"><span class="tally" aria-hidden="true"></span>Same-day response on every request</p>
        <h2 class="display text-[clamp(1.75rem,4vw,3rem)]">Spec your event package</h2>
      </div>
      <button type="button" class="bg-bg px-7 py-4 text-sm font-semibold text-ink transition-colors hover:bg-signal hover:text-white" data-drawer-open>
        Review quote list
      </button>
    </div>
  </section>
</Base>

<style>
  /* ---------- blueprint hero: grid paper, drawn plan, callouts ---------- */
  .bp-grid {
    background-image:
      linear-gradient(color-mix(in oklch, var(--color-line-dark) 55%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in oklch, var(--color-line-dark) 55%, transparent) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(120% 120% at 30% 40%, black 40%, transparent 100%);
  }
  .bp-draw {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: bp-draw 1.1s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) both;
    animation-delay: var(--bp-delay, 250ms);
  }
  /* dashed rooms: dasharray is decorative, draw via opacity instead */
  .bp-draw[stroke-dasharray='6 5'] {
    stroke-dasharray: 6 5;
    stroke-dashoffset: 0;
    opacity: 0;
    animation: bp-appear 0.8s ease-out both;
    animation-delay: var(--bp-delay, 250ms);
  }
  @keyframes bp-draw {
    to { stroke-dashoffset: 0; }
  }
  .bp-fade,
  .bp-fade-html,
  .bp-callout {
    opacity: 0;
    animation: bp-appear 0.9s ease-out 0.9s both;
  }
  .bp-callout { animation-delay: 1.1s; }
  @keyframes bp-appear {
    to { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .bp-draw,
    .bp-draw[stroke-dasharray='6 5'],
    .bp-fade,
    .bp-fade-html,
    .bp-callout {
      animation: none;
      opacity: 1;
      stroke-dashoffset: 0;
    }
  }
</style>
