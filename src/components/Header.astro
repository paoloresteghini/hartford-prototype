---
import { NAV, SITE, CAMERA_PRODUCTS } from '../data/catalog.js';

// Client-side search index: categories, subcategories, products
const searchIndex = [
  ...NAV.flatMap((division) =>
    division.categories.flatMap((cat) => [
      { label: `${cat.name} Rentals`, meta: `${division.label} · Category`, href: cat.slug },
      ...cat.subs.map((sub) => ({ label: sub.name, meta: `${cat.name} · ${division.label}`, href: sub.slug })),
    ])
  ),
  ...CAMERA_PRODUCTS.map((p) => ({
    label: `${p.brand} ${p.name}`,
    meta: `${p.sku} · ${p.typeLabel}`,
    href: p.href,
    img: p.img,
  })),
];
---

<a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[80] focus:bg-bg focus:text-ink focus:px-4 focus:py-2 focus:text-sm">
  Skip to content
</a>

<header class="sticky top-0 z-40 bg-ink text-bg" id="site-header">
  <!-- utility bar -->
  <div class="border-b border-line-dark/60">
    <div class="mx-auto flex max-w-[1440px] items-center justify-between gap-4 px-5 py-1.5 lg:px-10">
      <p class="mono-label text-muted-dark">Business &amp; education rentals only</p>
      <div class="hidden items-center gap-5 sm:flex">
        <p class="mono-label text-muted-dark">{SITE.locations.join(' · ')} — Nationwide overnight</p>
        <a href={SITE.phoneHref} class="mono-label link-draw text-bg">{SITE.phone}</a>
      </div>
    </div>
  </div>

  <!-- main bar -->
  <div class="relative">
    <div class="mx-auto flex max-w-[1440px] items-center justify-between gap-6 px-5 py-4 lg:px-10">
      <a href="/" class="group flex items-baseline gap-2.5" aria-label="Hartford Technology Rentals — home">
        <span class="display text-[1.35rem] leading-none tracking-tight">Hartford</span>
        <span class="tally relative -top-px" aria-hidden="true"></span>
      </a>

      <nav class="hidden lg:block" aria-label="Primary">
        <ul class="flex items-center gap-1">
          {NAV.map((division) => (
            <li class="nav-group" data-nav-group>
              <button
                type="button"
                class="flex items-center gap-1.5 px-4 py-2 text-[0.9375rem] font-medium text-bg/90 transition-colors hover:text-bg"
                aria-expanded="false"
                aria-haspopup="true"
                data-nav-toggle
              >
                {division.label}
                <svg class="chev h-3 w-3 opacity-60" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
                </svg>
              </button>

              <!-- mega panel -->
              <div class="mega-panel text-ink" data-mega-panel>
                <div class="mx-auto grid max-w-[1440px] grid-cols-[300px_1fr_340px] px-5 lg:px-10">
                  <!-- category rail -->
                  <ul class="border-r border-line py-6 pr-2" role="list">
                    {division.categories.map((cat, i) => (
                      <li>
                        <button
                          type="button"
                          class="mega-cat flex w-full items-center justify-between gap-3 px-4 py-2.5 text-left text-[0.9375rem] font-medium"
                          aria-expanded={i === 0 ? 'true' : 'false'}
                          data-mega-cat={`${division.id}-${i}`}
                        >
                          <span>{cat.name}</span>
                          <svg class="mega-cat-arrow h-3.5 w-3.5" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                            <path d="M2 7h9M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
                          </svg>
                        </button>
                      </li>
                    ))}
                  </ul>

                  <!-- subcategory panes -->
                  <div class="relative py-8 pl-10 pr-10">
                    {division.categories.map((cat, i) => (
                      <div
                        class:list={['mega-sub-pane grid-cols-2 content-start gap-x-8', { active: i === 0 }]}
                        data-mega-pane={`${division.id}-${i}`}
                      >
                        <div class="col-span-2 mb-4 flex items-baseline justify-between border-b border-line pb-3">
                          <p class="display-sub text-sm">{cat.name}</p>
                          <a href={cat.slug} class="mono-label link-draw text-ink-3 hover:text-ink">View all →</a>
                        </div>
                        {cat.subs.map((sub) => (
                          <a
                            href={sub.slug}
                            class="link-draw w-fit py-1.5 text-[0.9375rem] text-ink-2 transition-colors hover:text-ink"
                          >
                            {sub.name}
                          </a>
                        ))}
                        <p class="col-span-2 mt-5 text-sm text-ink-3">{cat.blurb}</p>
                      </div>
                    ))}
                  </div>

                  <!-- featured image -->
                  <div class="relative hidden overflow-hidden border-l border-line xl:block">
                    {division.categories.map((cat, i) =>
                      cat.img ? (
                        <a
                          href={cat.slug}
                          class:list={['mega-sub-pane absolute inset-0 grid-cols-1', { active: i === 0 }]}
                          data-mega-pane-img={`${division.id}-${i}`}
                        >
                          <img src={cat.img} alt="" class="h-full w-full object-cover" loading="lazy" />
                          <span class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink/80 to-transparent p-5 pt-14">
                            <span class="mono-label text-bg/80">Featured</span>
                            <span class="block text-lg font-semibold text-bg">{cat.name}</span>
                          </span>
                        </a>
                      ) : (
                        <div
                          class:list={['mega-sub-pane absolute inset-0 place-content-center bg-surface', { active: i === 0 }]}
                          data-mega-pane-img={`${division.id}-${i}`}
                        >
                          <p class="mono-label px-8 text-center text-ink-3">{cat.blurb}</p>
                        </div>
                      )
                    )}
                  </div>
                </div>
              </div>
            </li>
          ))}
          <li><a href="#" class="px-4 py-2 text-[0.9375rem] font-medium text-bg/90 transition-colors hover:text-bg">Event Solutions</a></li>
          <li><a href="#" class="px-4 py-2 text-[0.9375rem] font-medium text-bg/90 transition-colors hover:text-bg">About</a></li>
        </ul>
      </nav>

      <div class="flex items-center gap-2.5">
        <button type="button" class="p-2 text-bg/80 transition-colors hover:text-bg" aria-label="Search the fleet" aria-expanded="false" data-search-open>
          <svg class="h-[1.15rem] w-[1.15rem]" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.4" />
            <path d="M12.2 12.2L16 16" stroke="currentColor" stroke-width="1.4" stroke-linecap="square" />
          </svg>
        </button>
        <a href={SITE.phoneHref} class="mono-label hidden items-center gap-2 px-3 py-2 text-muted-dark transition-colors hover:text-bg md:flex lg:hidden xl:flex">
          <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 2h3l1.5 4L5.7 7.3a10 10 0 004 4L11 9.5l4 1.5v3a1 1 0 01-1 1A12 12 0 012 3a1 1 0 011-1z" stroke="currentColor" stroke-width="1.3"/></svg>
          {SITE.phone}
        </a>
        <button
          type="button"
          class="relative flex items-center gap-2.5 border border-line-dark px-4 py-2.5 text-sm font-medium transition-colors hover:border-bg hover:bg-bg hover:text-ink"
          data-drawer-open
        >
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2.5 3.5h9l1 8h-11l1-8zM5.5 5.5v-2a2.5 2.5 0 015 0" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" transform="translate(0 1)"/>
          </svg>
          <span class="hidden sm:inline">Quote List</span>
          <span
            class="absolute -right-2 -top-2 hidden h-5 min-w-5 items-center justify-center rounded-full bg-signal px-1 font-mono text-[0.6875rem] font-medium text-white"
            data-quote-badge
          >0</span>
        </button>
        <button type="button" class="-mr-1 p-2 lg:hidden" aria-label="Open menu" aria-expanded="false" data-sheet-open>
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M2 5h16M2 10h16M2 15h16" stroke="currentColor" stroke-width="1.5" />
          </svg>
        </button>
      </div>
    </div>

    <!-- search panel -->
    <div class="search-panel text-ink" data-search-panel hidden>
      <div class="mx-auto max-w-[1440px] px-5 py-6 lg:px-10">
        <form class="flex items-center gap-4 border-b-2 border-ink pb-3" role="search" data-search-form>
          <svg class="h-5 w-5 flex-none text-ink-3" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.4" />
            <path d="M12.2 12.2L16 16" stroke="currentColor" stroke-width="1.4" stroke-linecap="square" />
          </svg>
          <label class="sr-only" for="fleet-search">Search the fleet</label>
          <input
            id="fleet-search"
            type="search"
            placeholder="Search the fleet — try “PTZ”, “AK-UC4000” or “LED wall”"
            autocomplete="off"
            class="w-full bg-transparent text-lg font-medium placeholder:text-ink-3 focus:outline-none lg:text-xl"
            data-search-input
          />
          <button type="button" class="mono-label flex-none text-ink-3 transition-colors hover:text-ink" data-search-close>Esc</button>
        </form>
        <ul class="mt-2 divide-y divide-line empty:hidden" data-search-results></ul>
        <p class="mt-4 hidden text-sm text-ink-3" data-search-empty>
          No match in the fleet — the full inventory is deeper than the site. Call 888-520-5667 or add a note to your quote.
        </p>
      </div>
    </div>
  </div>
</header>

<script type="application/json" data-search-index set:html={JSON.stringify(searchIndex)} />

<!-- mobile nav sheet -->
<div class="fixed inset-0 z-[60] lg:hidden" hidden data-sheet-root>
  <div class="drawer-backdrop absolute inset-0 bg-ink/60 backdrop-blur-sm" data-sheet-close></div>
  <div class="sheet absolute inset-y-0 left-0 flex w-[min(24rem,88vw)] flex-col overflow-y-auto bg-bg text-ink shadow-2xl">
    <div class="flex items-center justify-between border-b border-line px-5 py-4">
      <span class="display text-lg">Hartford</span>
      <button type="button" class="p-2" aria-label="Close menu" data-sheet-close>
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5"/></svg>
      </button>
    </div>
    <nav class="flex-1 px-5 py-4" aria-label="Mobile">
      {NAV.map((division) => (
        <details class="faq border-b border-line">
          <summary class="flex items-center justify-between py-4">
            <span class="display-sub text-sm">{division.label}</span>
            <svg class="faq-icon h-4 w-4 text-ink-3" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.4"/></svg>
          </summary>
          <div class="faq-body">
            <div>
              {division.categories.map((cat) => (
                <details class="faq">
                  <summary class="flex items-center justify-between py-2.5 pl-3">
                    <span class="text-[0.9375rem] font-medium">{cat.name}</span>
                    <svg class="faq-icon h-3.5 w-3.5 text-ink-3" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.4"/></svg>
                  </summary>
                  <div class="faq-body">
                    <div class="pb-2 pl-6">
                      {cat.subs.map((sub) => (
                        <a href={sub.slug} class="block py-2 text-[0.9375rem] text-ink-2">{sub.name}</a>
                      ))}
                    </div>
                  </div>
                </details>
              ))}
            </div>
          </div>
        </details>
      ))}
      <a href="#" class="block border-b border-line py-4 display-sub text-sm">Event Solutions</a>
      <a href="#" class="block border-b border-line py-4 display-sub text-sm">About</a>
    </nav>
    <div class="border-t border-line px-5 py-4">
      <a href={SITE.phoneHref} class="mono-label text-ink-2">{SITE.phone} — 24/7 support</a>
    </div>
  </div>
</div>
